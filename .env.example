# ============================================================
# ACCOLTA — Variables d'environnement
# Copie ce fichier en .env.local et remplis les valeurs
# ============================================================

# --- Supabase (publiques, ok côté client) ---
# Récupère ces valeurs : supabase.com > ton projet > Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://XXXXXXXXXXXXXXXX.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# --- Supabase service role (SECRÈTE — jamais dans le code) ---
# Même page, section "service_role" — donne accès total à ta DB
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# --- Token admin (SECRÈTE — invente une chaîne longue et aléatoire) ---
# Ce token est vérifié côté serveur par l'API route /api/admin
# Génère-en un : openssl rand -hex 32
ADMIN_SECRET_TOKEN=remplace_par_une_chaine_aleatoire_longue

# --- Identifiants affichés dans le formulaire de connexion admin ---
NEXT_PUBLIC_ADMIN_EMAIL=admin@accolta.fr
NEXT_PUBLIC_ADMIN_PASSWORD=remplace_par_ton_mot_de_passe
